[Unit]
Description=Cursor EDAMAME verdict reader
After=default.target

[Service]
Type=oneshot
WorkingDirectory=__PACKAGE_ROOT__
ExecStart=__NODE_BIN__ __PACKAGE_ROOT__/service/verdict_reader.mjs --config __CONFIG_PATH__ --json
StandardOutput=append:__STATE_DIR__/cursor-verdict-reader.log
StandardError=append:__STATE_DIR__/cursor-verdict-reader.err
