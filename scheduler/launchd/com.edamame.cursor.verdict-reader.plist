<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.edamame.cursor.verdict-reader</string>
    <key>ProgramArguments</key>
    <array>
      <string>__NODE_BIN__</string>
      <string>__PACKAGE_ROOT__/service/verdict_reader.mjs</string>
      <string>--config</string>
      <string>__CONFIG_PATH__</string>
      <string>--json</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>StartInterval</key>
    <integer>180</integer>
    <key>StandardOutPath</key>
    <string>__STATE_DIR__/cursor-verdict-reader.log</string>
    <key>StandardErrorPath</key>
    <string>__STATE_DIR__/cursor-verdict-reader.err</string>
    <key>WorkingDirectory</key>
    <string>__PACKAGE_ROOT__</string>
  </dict>
</plist>
